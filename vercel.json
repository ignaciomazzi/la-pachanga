{
  "rewrites": [
    { "source": "/", "destination": "/index_local.html" },
    { "source": "/v2", "destination": "/index_local_v2.html" },
    { "source": "/apuestas", "destination": "/apuestas.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
